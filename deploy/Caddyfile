152-42-242-127.sslip.io {
	# /health đi thẳng tới api (không strip) — QA mở https://<domain>/health
	handle /health {
		reverse_proxy api:8000
	}

	# /api/* -> api, strip prefix; api chạy uvicorn --root-path /api nên /api/docs hoạt động
	handle_path /api/* {
		reverse_proxy api:8000
	}

	# /admin* -> admin console Streamlit (F6) — basic-auth lớp ngoài (defense-in-depth,
	# API /admin/* vẫn đòi X-Role curator). User: curator / pass: shb-curator-2026
	# (đổi pass = `caddy hash-password` rồi thay hash dưới đây — ghi chú trong report F6).
	handle /admin* {
		basic_auth {
			curator "$2a$14$EwFSTpagtF97z4QsWxGz4eAHpfxSY7/xkNUZEEitdtc6durgGT0UC"
		}
		# redirect /admin → /admin/ tại Caddy: streamlit tự redirect sẽ phát Location http://
		# (không biết đang sau TLS) làm rớt phiên basic-auth trên vài client
		@admin_noslash path /admin
		redir @admin_noslash /admin/ 308
		# không strip prefix: admin app chạy --server.baseUrlPath /admin
		reverse_proxy admin:8502
	}

	# còn lại -> chat UI
	handle {
		reverse_proxy ui:8501
	}
}
